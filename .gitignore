# =============================================================================
bin/
obj/
*.dll
*.exe
*.pdb
*.user
*.suo
*.cache
*.vspscc
*.vssscc
.vs/
packages/
*.nupkg
project.lock.json

# =============================================================================
# Rust
# =============================================================================
target/
Cargo.lock
**/*.rs.bk

# =============================================================================
# Go
# =============================================================================
vendor/
go.sum

# =============================================================================
# Node.js / JavaScript
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# =============================================================================
# Java / JVM
# =============================================================================
*.class
*.jar
*.war
*.ear

# =============================================================================
# IDE and editors
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# =============================================================================
# OS generated
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# Logs and temporary files
# =============================================================================
*.log
*.tmp
*.temp
*.bak
*.backup

# =============================================================================
# Secrets
# =============================================================================
.env
.env.local
.env.*.local
*.pem
*.key
*.sqlite*
secrets.json
credentials.json

# =============================================================================
# Published root release artifacts
# =============================================================================
# Keep only the root release directory so GitHub visitors can download final
# binaries without building. Child released/ and every lib/ are regenerated by
# Build/AggregateLib after pull.
!/released/
!/released/**
