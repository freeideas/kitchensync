# =============================================================================
# aitc framework
# =============================================================================
# The framework lives in its own repo (`push-aitc.py` / `pull-aitc.py`).
# Project push/pull stores project state, not framework copies.
/aitc/
**/aitc/
aitc.old/

# =============================================================================
# Regenerable per-device infrastructure and build products
# =============================================================================
/tools/
/tools
**/tools/
**/tools
/build/
/build
**/build/
**/build
/lib/
/lib
**/lib/
**/lib
**/released/
**/released

/tmp/
/tmp
**/tmp/
**/tmp
/reports/
/reports
**/reports/
**/reports
/sandboxes/
/sandboxes
**/sandboxes/
**/sandboxes

# Local PowerShell cache sometimes created when running from this workspace.
/Microsoft/

# Local credentials. `push-project.py` can encrypt ./creds/ to docs/creds.zip.
/creds/

# Transient run controls and process state.
/STOP.flag
/_FINAL.flag
/.orchestrator.lock
orchestrator.log
orchestrator.log.*

# AI agent instructions are local-device guidance, not project state.
/CLAUDE.md
/CODEX.md
/AGENTS.md
/.claude/

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
env/
.egg-info/
*.egg
dist/
*.whl

