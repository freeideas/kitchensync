# =============================================================================
# aitc framework (lives in its own repo — push-aitc.py / pull-aitc.py)
# =============================================================================
aitc/

# =============================================================================
# aitc-managed / generated artifacts (do not track)
# =============================================================================
tmp/
reports/
state/
build/
subpjx/
sandboxes/
tools/
creds/

# aitc on-disk state markers and locks
.orchestrator.lock
orchestrator.log
orchestrator.log.*
*_DIR.hash
*_REQFIX.hash
*_BUILD_*.hash
_*.hash
LAST_FAILURE.md
retries.json

# AI agent instructions (local only)
CLAUDE.md
CODEX.md
AGENTS.md

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
env/
.egg-info/
*.egg
dist/
*.whl

# =============================================================================
# C# / .NET
# =============================================================================
bin/
obj/
*.dll
*.exe
*.pdb
*.user
*.suo
*.cache
*.vspscc
*.vssscc
.vs/
packages/
*.nupkg
project.lock.json

# =============================================================================
# Rust
# =============================================================================
target/
Cargo.lock
**/*.rs.bk

# =============================================================================
# Go
# =============================================================================
vendor/
go.sum

# =============================================================================
# Node.js / JavaScript
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# =============================================================================
# Java / JVM
# =============================================================================
*.class
*.jar
*.war
*.ear

# =============================================================================
# IDE and editors
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# =============================================================================
# OS generated
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# Logs and temporary files
# =============================================================================
*.log
*.tmp
*.temp
*.bak
*.backup

# =============================================================================
# Secrets (never commit these)
# =============================================================================
.env
.env.local
.env.*.local
*.pem
*.key
*.sqlite*
secrets.json
credentials.json

# =============================================================================
# Released binaries (must come LAST to override *.exe, *.jar, *.bak, etc.)
# =============================================================================
!released/
!released/*
