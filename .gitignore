# Human-authored project inputs and supplied artifacts. These are part of the
# project mirror even when generic language rules above would ignore a file
# type such as .dll, .exe, .json, or .log.
!/specs/
!/specs/**
!/docs/
!/docs/**
!/extart/
!/extart/**
/specs/**/__pycache__/
/specs/**/*.py[cod]
/docs/**/__pycache__/
/docs/**/*.py[cod]
/extart/**/__pycache__/
/extart/**/*.py[cod]
