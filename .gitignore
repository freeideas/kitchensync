# =============================================================================
# aitc framework — lives in its own repo (push-aitc.py / pull-aitc.py)
# =============================================================================
aitc/
# Each carve gets a literal copy of aitc/ at carve-mint time. Same exclusion
# applies recursively: only the canonical workspace-root aitc/ ships, via the
# separate framework repo.
**/aitc/

# Old framework copy (predecessor of the current aitc/, kept locally only)
aitc.old/

# =============================================================================
# Regenerable per-device infrastructure
# =============================================================================
# JDK + Gradle. Re-downloaded by the DownloadCompiler job on each device.
tools/
**/tools/
# Gradle build cache. Regenerated by the Build job; first builds are slower.
build/
**/build/

# =============================================================================
# Transient orchestrator artifacts (regenerated on next run; useless to push)
# =============================================================================
tmp/
reports/
**/reports/
sandboxes/

# Per-project state files that are transient (orchestrator wipes / replaces
# them on startup). Persistent sentinels in state/ (DIAGNOSE_DIARY,
# AI_RATE_LIMIT_HALT, ROOT_SPEC_PENDING_APPROVAL) DO get pushed — they need
# to survive a round-trip so a halted build resumes halted on the other
# device.
**/state/retries.json
**/state/LAST_FAILURE.md
**/state/DIAGNOSE_PENDING.md
**/state/DIAGNOSE_EXHAUSTED.md

# Single-instance lock + log
.orchestrator.lock
orchestrator.log
orchestrator.log.*

# =============================================================================
# Local creds (the push-project.py script encrypts to docs/creds.zip)
# =============================================================================
creds/

# =============================================================================
# AI agent instructions — local-device guidance, not project state
# =============================================================================
CLAUDE.md
CODEX.md
AGENTS.md
.claude/

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
env/
.egg-info/
*.egg
dist/
*.whl

# =============================================================================
# C# / .NET
# =============================================================================
bin/
obj/
*.dll
*.exe
*.pdb
*.user
*.suo
*.cache
*.vspscc
*.vssscc
.vs/
packages/
*.nupkg
project.lock.json

# =============================================================================
# Rust
# =============================================================================
target/
Cargo.lock
**/*.rs.bk

# =============================================================================
# Go
# =============================================================================
vendor/
go.sum

# =============================================================================
# Node.js / JavaScript
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# =============================================================================
# Java / JVM — broad exclusion; per-carve released/ + parent lib/ are re-
# included below via !**/released/** and !**/lib/**.
# =============================================================================
*.class
*.jar
*.war
*.ear

# =============================================================================
# IDE and editors
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# =============================================================================
# OS generated
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# Logs and temporary files
# =============================================================================
*.log
*.tmp
*.temp
*.bak
*.backup

# =============================================================================
# Secrets (never commit these)
# =============================================================================
.env
.env.local
.env.*.local
*.pem
*.key
*.sqlite*
secrets.json
credentials.json

# =============================================================================
# Re-include framework outputs — must come LAST to override *.jar above.
# Each carve ships released/<name>.jar + released/<name>_MCP.jar; parents
# also have lib/ with the aggregated children's release artifacts. Both are
# tracked so a fresh clone on another device resumes the build from where
# it stopped without re-running every WriteCode/Build dispatch.
# =============================================================================
!**/released/
!**/released/**
!**/lib/
!**/lib/**

# Note about hash markers: the prior version of this file excluded
# `_*.hash`, `*_DIR.hash`, `*_REQFIX.hash`, `*_BUILD_*.hash`. Those rules
# threw away the project-scoped done markers (`_ReqGen.hash`,
# `_WriteCode.hash`, `_NextCarve.hash`, `_Build.hash`, etc.), so a Device-B
# resume would treat every job as un-done and re-run the entire pipeline.
# The exclusions are gone; all `*.hash` markers ship.
