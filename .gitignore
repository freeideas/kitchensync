# =============================================================================
# Outer project repo -- the product aitc is building plus its human inputs.
#
# Normally named `disabled.gitignore` so the OS, VS Code, and git plugins do
# not see this workspace as a git repo. push-project.py / pull-project.py
# rename it to `.gitignore` only while they run.
#
# push-project.py is a dumb mirror: everything not matched below is pushed.
# So this file is the ONLY thing keeping the framework tree and per-device /
# transient / build state out of the project backup.
# =============================================================================

# -----------------------------------------------------------------------------
# aitc framework -- its OWN repo (push-aitc.py / pull-aitc.py). Never part of
# the project repo, and pull-project.py preserves ./aitc/ across a pull.
# -----------------------------------------------------------------------------
aitc/
aitc.old/

# -----------------------------------------------------------------------------
# aitc operational state -- per-device, regenerated, never backed up here.
#   state/   SQLite db, halt/punt/diagnosis files, pass flags
#   reports/ job transcripts and mechanical logs
#   tmp/     scratch and safe_delete tombstones
#   tools/   provisioned compiler/runtime toolchains (large, per-device)
# -----------------------------------------------------------------------------
state/
reports/
tmp/
tools/

# -----------------------------------------------------------------------------
# AI agent instruction files -- local to this checkout.
# -----------------------------------------------------------------------------
CLAUDE.md
CODEX.md
AGENTS.md

# -----------------------------------------------------------------------------
# Build output under ./proj/ (regenerable; the source that produces it IS
# tracked). Covers the languages aitc can target.
# -----------------------------------------------------------------------------
# Rust
target/
**/*.rs.bk
# C# / .NET
bin/
obj/
*.dll
*.pdb
*.user
.vs/
# Go
vendor/
# Node.js
node_modules/
npm-debug.log*

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/

# -----------------------------------------------------------------------------
# Editor / IDE
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS generated
# -----------------------------------------------------------------------------
.DS_Store
._*
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Logs and temporary files
# -----------------------------------------------------------------------------
*.log
*.tmp
*.bak

# -----------------------------------------------------------------------------
# Secrets -- never commit
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
creds/
secrets.json
credentials.json
